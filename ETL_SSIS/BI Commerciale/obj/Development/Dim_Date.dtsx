            <component
              refId="Package\Tâche de flux de données\Dimension à variation lente"
              componentClassID="Microsoft.SCD"
              contactInfo="Dimension à variation lente;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; Tous droits réservés; http://www.microsoft.com/sql/support;3"
              description="Met à jour une dimension d'entrepôt de données (Data Warehouse) SQL Server Analysis Services. Mettez à jour les enregistrements de dimension qui sont déjà présents et insérez ceux qui ne le sont pas. Par exemple, mettez à jour la table DimProduct de la base de données OLAP AdventureWorksDW avec les données de la table Products dans la base de données OLTP AdventureWorks."
              name="Dimension à variation lente"
              version="3">
              <properties>
                <property
                  dataType="System.String"
                  description="Spécifie l'instruction SELECT utilisée pour créer un ensemble de lignes du schéma."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT [Annee], [Mois], [PERIODE] FROM [dbo].[Dim_Date]</property>
                <property
                  dataType="System.String"
                  description="Spécifie la clause WHERE dans l'instruction SELECT qui sélectionne la ligne actuelle parmi les lignes comportant des clés de travail identiques."
                  name="CurrentRowWhere"></property>
                <property
                  dataType="System.Boolean"
                  description="Indique si les mises à jour d'attribut d'historique sont dirigées sur la sortie de la transformation pour les mises à jour d'attribut de validation."
                  name="UpdateChangingAttributeHistory">true</property>
                <property
                  dataType="System.Boolean"
                  description="Indique si la transformation échoue lorsque les colonnes comportant des attributs fixes contiennent des modifications."
                  name="FailOnFixedAttributeChange">false</property>
                <property
                  dataType="System.String"
                  description="Spécifie le nom de la colonne pour le membre déduit."
                  name="InferredMemberIndicator"></property>
                <property
                  dataType="System.Boolean"
                  description="Indique si les mises à jour de membre déduit sont détectées."
                  name="EnableInferredMember">true</property>
                <property
                  dataType="System.Boolean"
                  description="Indique si la transformation échoue lorsque la recherche d'un enregistrement existant échoue."
